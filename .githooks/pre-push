#!/bin/bash

# Pre-push hook: prevent pushing commits with default/generic author or committer identities.
# Install: git config core.hooksPath .githooks

blocked='ubuntu|root|ec2-user|centos|fedora|debian|admin|bitnami|azureuser|gce-user|runner|jenkins|nobody|user|test|default|guest'

failed=0
while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip branch deletions
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # For new branches, check commits not reachable from any remote branch
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha --not --remotes"
    else
        range="$remote_sha..$local_sha"
    fi

    for sha in $(git log --format='%H' $range); do
        author=$(git log -1 --format='%an <%ae>' "$sha")
        committer=$(git log -1 --format='%cn <%ce>' "$sha")
        for identity in "$author" "$committer"; do
            if echo "$identity" | grep -qiw -E "$blocked"; then
                echo "ERROR: Commit $sha has a default/generic identity: $identity" >&2
                failed=1
            fi
        done
    done
done

if [ "$failed" -eq 1 ]; then
    echo >&2
    echo "Push blocked. Please fix your git identity with:" >&2
    echo "  git config user.name \"Your Name\"" >&2
    echo "  git config user.email \"your@email.com\"" >&2
    echo "Then amend the affected commits." >&2
    exit 1
fi
