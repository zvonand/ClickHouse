<clickhouse>
    <storage_configuration>
        <disks>
            <!-- Disk for test 04068_s3_disk_settings_override.
                 Uses a small max_single_part_upload_size to force multipart upload.
                 The global <s3> section sets a large value for this endpoint;
                 the test verifies that disk config wins. -->
            <s3_disk_04068>
                <type>s3</type>
                <endpoint>http://localhost:11111/test/04068_s3_disk_settings_override/</endpoint>
                <access_key_id>clickhouse</access_key_id>
                <secret_access_key>clickhouse</secret_access_key>
                <max_single_part_upload_size>10000</max_single_part_upload_size>
            </s3_disk_04068>
        </disks>
        <policies>
            <s3_04068>
                <volumes>
                    <main>
                        <disk>s3_disk_04068</disk>
                    </main>
                </volumes>
            </s3_04068>
        </policies>
    </storage_configuration>
</clickhouse>
