--JSON_VALUE with Tuple--
('1','hello')
('1',NULL)
(NULL,NULL)
--JSON_VALUE with Array--
['1','hello']
['1',NULL]
[NULL]
--JSON_VALUE with nested structure--
(['1','2'],'3')
(('1','2'),['3'])
[('10',NULL)]
--JSON_VALUE preserves all value types--
('null','true','1.5','text',NULL)
--JSON_VALUE with multiple rows--
('Alice','30')
('Bob','25')
(NULL,NULL)
--JSON_VALUE with nullable=0--
('1','')
['1','']
--JSON_EXISTS with Tuple--
(1,0)
--JSON_EXISTS with Array--
[1,0,1]
--JSON_EXISTS with nested structure--
([1,0],1)
--JSON_QUERY with Tuple--
('[[1,2]]','[{"c":3}]')
--JSON_QUERY with Array--
['[[1,2]]','']
--Named tuple preserves element names--
1
hello
1
0
[[1,2]]
[{"c":3}]
2
--Error cases--
